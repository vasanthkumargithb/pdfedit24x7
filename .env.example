# ─── PDFPro Environment Variables ───────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to Git.

# ── Required for Word→PDF and PDF→Word conversions ────────────────────────────
# Sign up at https://cloudconvert.com and generate a Sandbox or Production API key
CLOUDCONVERT_API_KEY=

# ── Optional: Your site's public URL (used in emails, OG meta, sitemaps) ──────
NEXT_PUBLIC_SITE_URL=https://pdfedit24x7.com

# ── Optional: Contact form email service ──────────────────────────────────────
# Resend (https://resend.com) — recommended for transactional email
RESEND_API_KEY=

# ── Optional: Analytics ───────────────────────────────────────────────────────
# Plausible or Google Analytics Measurement ID
NEXT_PUBLIC_GA_ID=

